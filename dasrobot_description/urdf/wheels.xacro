<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
     
    <!-- Макросы -->
    <xacro:macro name="wheel_link" params="prefix">
        <link name="${prefix}_wheel_link">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
                <material name="red" />
            </visual>
            <collision>
                <geometry>
                    <!-- <cylinder radius="${wheel_radius}" length="${wheel_length}" /> -->
                    <sphere radius="${wheel_radius}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
            </collision>
            <xacro:cylinder_inertial mass="${wheel_mass}" radius="${wheel_radius}" length="${wheel_length}"/>
        </link>
    </xacro:macro>

    <xacro:macro name="caster_link" params="prefix">
        <link name="${prefix}_caster_link">
            <visual>
                <geometry>
                    <sphere radius="${caster_radius}" />
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <material name="red" />
            </visual>
            <collision>
                <geometry>
                    <sphere radius="${caster_radius}" />
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0" />
            </collision>
            <xacro:sphere_inertial mass="${caster_mass}" radius="${caster_radius}" />
        </link>
    </xacro:macro>

    <!-- Ссылки -->
    <xacro:wheel_link prefix="left" />
    <xacro:wheel_link prefix="right" />
    <xacro:caster_link prefix="front" />
    <xacro:caster_link prefix="rear" />

    <!-- Соединения -->
    <joint name="base_left_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_wheel_link" />
        <origin xyz="0 ${wheel_separation / 2} 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_right_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_wheel_link" />
        <origin xyz="0 ${-wheel_separation / 2} 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_front_caster_joint" type="fixed">
        <parent link="base_link" />
        <child link="front_caster_link" />
        <origin xyz="${caster_separation / 2} 0 0" />
    </joint>

    <joint name="base_rear_caster_joint" type="fixed">
        <parent link="base_link" />
        <child link="rear_caster_link" />
        <origin xyz="${-caster_separation / 2} 0 0" />
    </joint>

</robot>